<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Positioning Lab</title>

  <style type="text/css">
   
    html {
      box-sizing: border-box;
    }

    *,
    *:before,
    *:after {
      box-sizing: inherit;
    }

    body {
      background-color: #ECECEC;
      font-weight: bold;
      font-family: Tahoma, Geneva, sans-serif;
      color: #FFF;
      text-align: center;
      line-height: 24px;
    }

    h1 {
      color: #000;
      font-weight: normal;
      padding: 20px;
    }

    #wrapper {
      width: 800px;
      margin: 0 auto;
    }

  
    #navy,
    #teal,
    #blue,
    #aqua {
      float: left;
      width: 48%;
      height: 200px;
      margin: 1%;
      padding-top: 10px;
      text-shadow: 2px 2px #000;
    }

    #footer {
      clear: both;
      width: 98%;
      margin: 1%;
      height: 60px;
      padding-top: 15px;
      text-shadow: 2px 2px #000;
    }

  
    #navy { background-color: #001f3f; }
    #teal { background-color: #39CCCC; }
    #blue { background-color: #0074D9; }
    #aqua { background-color: #7FDBFF; }
    #footer { background-color: #666; }
  </style>
</head>

<body>
  <h1>float-1</h1>

  <section id="wrapper">
    <div id="navy">Navy</div>
    <div id="teal">Teal</div>
    <div id="blue">Blue</div>
    <div id="aqua">Aqua</div>
    <div id="footer">Footer</div>
  </section>

</body>

</html>